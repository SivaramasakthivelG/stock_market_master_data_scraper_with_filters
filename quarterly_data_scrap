# STAGE 5 – SAVE QUARTERLY
# ══════════════════════════════════════════════════════════════════════════════

def save_quarterly(df: pd.DataFrame) -> None:
    if df.empty:
        print("⚠ No quarterly data to save.")
        return
    df.to_csv(QUARTERLY_CSV, index=False)
    print(f"✅ Quarterly features saved → {QUARTERLY_CSV}  ({len(df)} rows)")


