def main():
    _run_tests()

    print(f"\nSave directory : {SAVE_DIR}")
    print(f"Events CSV     : {EVENTS_CSV}")
    print(f"Quarterly CSV  : {QUARTERLY_CSV}\n")

    # Stage 1
    symbols = fetch_nse_symbols()

    # Stage 2
    events = screen_for_doubling(symbols)

    # Stage 3
    events_df = save_events(events)

    # Stage 4
    quarterly_df = fetch_quarterly_features(events_df)

    # Stage 5
    save_quarterly(quarterly_df)

    print("\n🏁 Pipeline complete.")
    print(f"   Doubling events  : {len(events_df)}")
    print(f"   Quarterly rows   : {len(quarterly_df)}")

    if IN_COLAB:
        from google.colab import files
        files.download(str(EVENTS_CSV))
        files.download(str(QUARTERLY_CSV))


if __name__ == "__main__":
    main()
