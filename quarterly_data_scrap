# SELF-TESTS
# ══════════════════════════════════════════════════════════════════════════════

def _run_tests():
    # clean_number
    assert clean_number("1,234") == 1234.0
    assert clean_number("12.5%") == 12.5
    assert clean_number("₹1,000") == 1000.0
    assert np.isnan(clean_number("-"))
    assert np.isnan(clean_number("N/A"))
    assert np.isnan(clean_number(None))
    assert clean_number(42) == 42.0

    # quarter_label_to_end_date – including previously broken non-quarter months
    cases = {
        "Mar 2025": "2025-03-31",
        "Dec 2023": "2023-12-31",
        "Jun 2024": "2024-06-30",
        "Jan 2024": "2024-01-31",
        "Feb 2024": "2024-02-29",   # leap year
        "Apr 2023": "2023-04-30",
        "Nov 2021": "2021-11-30",
    }
    for label, expected in cases.items():
        result = quarter_label_to_end_date(label)
        assert str(result.date()) == expected, f"{label}: got {result.date()}"

    assert pd.isna(quarter_label_to_end_date("Invalid"))
    assert pd.isna(quarter_label_to_end_date(None))

    # wide -> long P&L conversion
    dummy = pd.DataFrame({
        "Particulars": ["Sales", "Other income", "Net profit"],
        "Mar 2024": [100, 10, 30],
        "Jun 2024": [110, 12, 33],
    })
    master = _wide_pnl_table_to_master(dummy, "TEST.NS")
    assert len(master) == 6
    assert set(master["quarter_end"].astype(str).unique()) == {"2024-03-31", "2024-06-30"}
    assert {"sales", "other_income", "net_profit"}.issubset(set(master["line_item_key"].unique()))

    print("All self-tests passed ✅")


