# STAGE 4 – QUARTERLY FINANCIALS  (Screener.in)
# ══════════════════════════════════════════════════════════════════════════════

def _wide_pnl_table_to_master(raw: pd.DataFrame, nse_symbol: str) -> pd.DataFrame:
    """
    Convert Screener's wide quarterly P&L table into a long master table.

    Output columns:
      stock, statement_type, quarter_label, quarter_end, line_item, line_item_key, value
    """
    if raw is None or raw.empty:
        return pd.DataFrame()

    table = raw.copy()
    table = table.dropna(how="all")
    if table.shape[1] < 2:
        return pd.DataFrame()

    first_col = table.columns[0]
    table = table.set_index(first_col).T.reset_index()
    table.columns.name = None
    table = table.rename(columns={"index": "quarter_label"})
    table["quarter_end"] = table["quarter_label"].apply(quarter_label_to_end_date)
    table = table.dropna(subset=["quarter_end"])
    if table.empty:
        return pd.DataFrame()

    value_cols = [c for c in table.columns if c not in {"quarter_label", "quarter_end"}]
    if not value_cols:
        return pd.DataFrame()

    long_df = table.melt(
        id_vars=["quarter_label", "quarter_end"],
        value_vars=value_cols,
        var_name="line_item",
        value_name="value",
    )
    long_df["value"] = long_df["value"].apply(clean_number)
    long_df = long_df.dropna(subset=["value"])
    long_df["stock"] = nse_symbol
    long_df["statement_type"] = "pnl"
    long_df["line_item_key"] = long_df["line_item"].apply(normalize_line_item)
    long_df = long_df[[
        "stock",
        "statement_type",
        "quarter_label",
        "quarter_end",
        "line_item",
        "line_item_key",
        "value",
    ]].copy()
    long_df["quarter_end"] = pd.to_datetime(long_df["quarter_end"]).dt.date
    return long_df


def _screener_quarterly(nse_symbol: str) -> pd.DataFrame:
    """
    Scrape the quarterly results table from Screener.in.
    Returns a long master table with all quarterly P&L line items.
    """
    slug = nse_symbol.replace(".NS", "")
    url = f"https://www.screener.in/company/{slug}/consolidated/"

    try:
        resp = session.get(url, timeout=REQUEST_TIMEOUT)
        resp.raise_for_status()
    except Exception:
        return pd.DataFrame()

    soup = BeautifulSoup(resp.text, "lxml")
    tables = soup.find_all("table", class_="data-table")
    if not tables:
        return pd.DataFrame()

    # The first data-table is usually the quarterly P&L
    try:
        raw = pd.read_html(StringIO(str(tables[0])))[0]
    except Exception:
        return pd.DataFrame()

    return _wide_pnl_table_to_master(raw, nse_symbol)


def fetch_quarterly_features(events_df: pd.DataFrame) -> pd.DataFrame:
    """
    For every stock in events_df, pull quarterly P&L from Screener.in
    and keep only quarters that fall within QUARTER_LOOKBACK_DAYS of the event.
    """
    if events_df.empty:
        return pd.DataFrame()

    frames = []
    stocks = events_df["stock"].unique().tolist()
    print(f"\nFetching quarterly data for {len(stocks)} stocks …")

    for symbol in stocks:
        qdf = _screener_quarterly(symbol)
        if qdf.empty:
            print(f"  ✗ {symbol}: no quarterly data")
            continue

        event_row = events_df.loc[events_df["stock"] == symbol].iloc[0]
        cutoff = pd.Timestamp(event_row["double_date"]) - pd.Timedelta(days=QUARTER_LOOKBACK_DAYS)
        qdf["quarter_end"] = pd.to_datetime(qdf["quarter_end"])
        qdf = qdf[qdf["quarter_end"] >= cutoff]

        if not qdf.empty:
            frames.append(qdf)
            print(f"  ✔ {symbol}: {len(qdf)} P&L rows")

        time.sleep(SCREENER_DELAY)

    if not frames:
        return pd.DataFrame()

    out = pd.concat(frames, ignore_index=True)
    out.sort_values(["stock", "quarter_end", "line_item_key"], inplace=True)
    return out


